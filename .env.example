NODE_ENV=production
PORT=3000

# Use a long random value with at least 32 characters.
JWT_SECRET=replace-with-a-long-random-secret

# SQLite database path, relative to the project root or absolute.
DB_PATH=database/copa_presidio.sqlite

# Admin bootstrap credentials. Change these before publishing.
ADMIN_ACCESS_CODE=replace-with-admin-code
ADMIN_PASSWORD=replace-with-admin-password

# Optional: comma-separated allowed origins, for example:
# CORS_ORIGIN=https://seudominio.com.br,https://www.seudominio.com.br
CORS_ORIGIN=

# Optional but recommended: 32 random bytes encoded as base64.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_KEY=replace-with-32-byte-base64-key
